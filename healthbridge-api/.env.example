# HealthBridge AI — Environment Configuration
# Copy this file to .env and fill in your values

# ─── App ───
APP_NAME=HealthBridge AI
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:8081,exp://

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthbridge
DATABASE_ECHO=false

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── LLM APIs ───
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
LLM_TIMEOUT=15
LLM_MAX_RETRIES=3

# ─── JWT Auth ───
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ─── External APIs ───
GOOGLE_MAPS_API_KEY=your-google-maps-key
ESANJEEVANI_API_URL=https://esanjeevani.mohfw.gov.in/api

# ─── Rate Limiting ───
RATE_LIMIT_PER_MINUTE=60
